rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /students/{studentId} {
      allow read, write: if true;
    }
    match /custom_courses/{courseId} {
      allow read, write: if true;
    }
    match /custom_homeworks/{homeworkId} {
      allow read, write: if true;
    }
    match /config/system {
      allow read, write: if true;
    }
  }
}
